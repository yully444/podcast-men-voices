---
const baseUrl = import.meta.env.BASE_URL;
const homeUrl = baseUrl;

const pageTitle = "Условия отмены и возврата — Чего хочет мужчина?";
const pageDescription = "Правила отмены участия и возврата средств для мастерской-тренинга «Чего хочет мужчина?», Батуми, 31 мая 2026.";
const ogImage = new URL(`${baseUrl}sharing.jpg`, Astro.site).toString();
const pageUrl = new URL(`${baseUrl}refund/`, Astro.site).toString();
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={pageDescription} />

  <meta property="og:type" content="article" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:site_name" content="Чего хочет мужчина" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:image" content={ogImage} />

  <link rel="icon" type="image/png" sizes="32x32" href={`${baseUrl}favicon/favicon-32x32.png`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${baseUrl}favicon/favicon-16x16.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${baseUrl}favicon/apple-touch-icon.png`} />
  <link rel="manifest" href={`${baseUrl}favicon/site.webmanifest`} />
  <link rel="shortcut icon" href={`${baseUrl}favicon/favicon.ico`} />
  <title>{pageTitle}</title>

  <!-- Brand fonts used in the footer, to match the home page -->
  <style is:inline>
    @font-face { font-family: 'Unbounded'; font-style: normal; font-weight: 200 900; font-display: swap; src: url('/fonts/unbounded-cyrillic.woff2') format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
    @font-face { font-family: 'Unbounded'; font-style: normal; font-weight: 200 900; font-display: swap; src: url('/fonts/unbounded-latin.woff2') format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
    @font-face { font-family: 'JetBrains Mono'; font-style: normal; font-weight: 100 800; font-display: swap; src: url('/fonts/jetbrainsmono-cyrillic.woff2') format('woff2'); unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116; }
    @font-face { font-family: 'JetBrains Mono'; font-style: normal; font-weight: 100 800; font-display: swap; src: url('/fonts/jetbrainsmono-latin.woff2') format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD; }
  </style>

  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      background: #fbfaf7;
      color: #1a1a1a;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      font-size: 16px;
      line-height: 1.6;
      font-weight: 400;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; }

    /* Sticky top header — brand + back-to-home */
    .siteHeader {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(251, 250, 247, 0.92);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-bottom: 1px solid #e8e4dc;
    }
    .siteHeaderInner {
      max-width: 760px;
      margin: 0 auto;
      padding: 14px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: #1a1a1a;
    }
    .brandMark {
      width: 24px;
      height: 24px;
      background: #e8951f;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      font-weight: 800;
      font-size: 14px;
      color: #1a1a1a;
    }
    .brandName {
      font-size: 14px;
      font-weight: 700;
      letter-spacing: -0.005em;
    }
    .backLink {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 500;
      color: #6b6b6b;
      text-decoration: none;
      transition: color 160ms;
    }
    .backLink:hover { color: #1a1a1a; }

    /* Document body */
    .doc {
      max-width: 760px;
      margin: 0 auto;
      padding: 26px 32px 0;
    }

    .docKicker {
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #8a8780;
      margin-bottom: 16px;
    }
    h1 {
      font-size: 32px;
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.015em;
      margin: 0 0 12px;
      color: #1a1a1a;
    }
    .docLead {
      font-size: 16px;
      line-height: 1.6;
      color: #555;
      margin: 0 0 32px;
      padding-bottom: 24px;
      border-bottom: 1px solid #e8e4dc;
    }

    h2 {
      font-size: 19px;
      font-weight: 700;
      line-height: 1.3;
      letter-spacing: -0.005em;
      margin: 32px 0 12px;
      color: #1a1a1a;
    }
    p {
      margin: 0 0 14px;
      color: #2a2a2a;
    }
    p:last-child { margin-bottom: 0; }

    ul.refundList {
      list-style: none;
      margin: 0 0 8px;
      padding: 0;
    }
    ul.refundList li {
      position: relative;
      padding: 10px 0 10px 18px;
      border-bottom: 1px dashed #e8e4dc;
      color: #2a2a2a;
    }
    ul.refundList li:last-child { border-bottom: 0; }
    ul.refundList li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 19px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #e8951f;
    }

    strong { font-weight: 600; }

    a.docLink {
      color: #1a1a1a;
      text-decoration: underline;
      text-decoration-color: #c9c5bd;
      text-underline-offset: 3px;
      transition: text-decoration-color 160ms;
    }
    a.docLink:hover { text-decoration-color: #1a1a1a; }

    /* Dark footer — compact version (brand + meta row) */
    .siteFooter {
      background: #2b2b29;
      color: #ece6d8;
      margin-top: 26px;
    }
    .siteFooterInner {
      max-width: 760px;
      margin: 0 auto;
      padding: 48px 32px 32px;
    }
    .footerBrand {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 24px;
      text-decoration: none;
      color: inherit;
    }
    .footerMark {
      width: 32px;
      height: 32px;
      background: #e8951f;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: 'Unbounded', -apple-system, BlinkMacSystemFont, sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: #1a1a18;
    }
    .footerBrandName {
      font-family: 'Unbounded', -apple-system, BlinkMacSystemFont, sans-serif;
      font-weight: 800;
      letter-spacing: -0.02em;
      font-size: 16px;
      line-height: 1.1;
      color: #ece6d8;
    }
    .footerBrandTag {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: 0.22em;
      color: rgba(236, 230, 216, 0.5);
      margin-top: 4px;
    }
    .footerMeta {
      padding-top: 24px;
      border-top: 1px solid rgba(236, 230, 216, 0.12);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: 0.18em;
      color: rgba(236, 230, 216, 0.5);
    }
    .footerLinks {
      display: flex;
      gap: 14px;
      align-items: center;
      flex-wrap: wrap;
    }
    .footerLinks a {
      color: rgba(236, 230, 216, 0.75);
      text-decoration: none;
      transition: color 160ms;
    }
    .footerLinks a:hover { color: #e8951f; }
    .footerSep { color: rgba(236, 230, 216, 0.25); }

    @media (max-width: 640px) {
      .siteHeaderInner { padding: 12px 20px; }
      .doc { padding: 22px 20px 0; }
      .siteFooterInner { padding: 36px 20px 28px; }
      h1 { font-size: 26px; }
      h2 { font-size: 17px; margin-top: 28px; }
      body { font-size: 15px; }
      .docLead { font-size: 15px; }
    }
  </style>
</head>
<body>
  <header class="siteHeader">
    <div class="siteHeaderInner">
      <a href={homeUrl} class="brand">
        <span class="brandMark">?</span>
        <span class="brandName">Чего хочет мужчина</span>
      </a>
      <a href={homeUrl} class="backLink">
        <span aria-hidden="true">←</span>
        <span>На главную</span>
      </a>
    </div>
  </header>

  <main class="doc">
    <h1>Правила отмены и&nbsp;возврата средств</h1>
    <p class="docLead">
      Документ описывает условия отмены участия и возврата средств для мастерской-тренинга «Чего хочет мужчина?» — Батуми, 31&nbsp;мая&nbsp;2026.
    </p>

    <h2>Правила отмены и возврата средств по желанию участника</h2>
    <ul class="refundList">
      <li><strong>от&nbsp;6 до&nbsp;14&nbsp;дней</strong> до начала мероприятия&nbsp;– возвращается <strong>100%</strong> от номинальной стоимости.</li>
      <li><strong>от&nbsp;3 до&nbsp;5&nbsp;дней</strong> до начала мероприятия&nbsp;– возвращается только <strong>50%</strong> от номинальной стоимости. При оплате суммы бронирования&nbsp;– удерживается только оплаченная сумма.</li>
      <li><strong>менее, чем за 3&nbsp;дня</strong> до начала мероприятия&nbsp;– возврат не осуществляется.</li>
    </ul>

    <h2>Срок полной оплаты</h2>
    <p>
      Полная стоимость участия должна быть оплачена не&nbsp;позднее, чем за&nbsp;3&nbsp;дня до начала мероприятия.
    </p>

    <h2>Как оформить возврат</h2>
    <p>
      Для отмены и&nbsp;возврата средств необходимо написать организатору текстовое сообщение и&nbsp;выслать данные карты, с&nbsp;которой осуществлялась оплата, имя и&nbsp;фамилию получателя (латиницей).
    </p>
    <p>
      Организатор: Анри Савиновский, <a class="docLink" href="https://t.me/sensologist" target="_blank" rel="noopener noreferrer">@sensologist</a>.
    </p>
  </main>

  <footer class="siteFooter">
    <div class="siteFooterInner">
      <a href={homeUrl} class="footerBrand">
        <span class="footerMark">?</span>
        <div>
          <div class="footerBrandName">Чего хочет мужчина</div>
          <div class="footerBrandTag">МАСТЕРСКАЯ-ТРЕНИНГ • БАТУМИ</div>
        </div>
      </a>
      <div class="footerMeta">
        <span>© 2026 — права защищены</span>
        <div class="footerLinks">
          <a href={homeUrl}>На главную</a>
          <span class="footerSep">·</span>
          <a href="https://t.me/sensologist" target="_blank" rel="noopener noreferrer">@sensologist</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
