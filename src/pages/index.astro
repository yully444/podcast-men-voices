// Build the torn-hole SVG paths server-side using a seeded RNG.
// Mirrors the algorithm from the design source (primitives.jsx → TornHole).
function buildTornHole() {
  let s = 7;
  const rnd = () => {
    s = (s * 9301 + 49297) % 233280;
    return s / 233280;
  };
  const cx = 500;
  const cy = 500;
  const rx = 360;
  const ry = 380;
  const N = 220;
  const pts: [number, number][] = [];
  for (let i = 0; i < N; i++) {
    const a = (i / N) * Math.PI * 2;
    const slow =
      Math.sin(a * 3 + 0.7) * 0.04 + Math.cos(a * 5 - 1.2) * 0.03;
    const jitter = (rnd() - 0.5) * 0.06;
    const notch = rnd() > 0.94 ? -0.07 - rnd() * 0.05 : 0;
    const jr = 1 + slow + jitter + notch;
    pts.push([
      cx + Math.cos(a) * rx * jr,
      cy + Math.sin(a) * ry * jr,
    ]);
  }
  let outer = `M ${pts[0][0].toFixed(1)} ${pts[0][1].toFixed(1)}`;
  for (let i = 1; i < N; i++)
    outer += ` L ${pts[i][0].toFixed(1)} ${pts[i][1].toFixed(1)}`;
  outer += " Z";

  const innerPts = pts.map(([x, y]) => {
    const dx = x - cx;
    const dy = y - cy;
    const inset = 16 + rnd() * 6;
    const len = Math.hypot(dx, dy);
    return [x - (dx / len) * inset, y - (dy / len) * inset];
  });
  let inner = `M ${innerPts[0][0].toFixed(1)} ${innerPts[0][1].toFixed(1)}`;
  for (let i = 1; i < N; i += 2)
    inner += ` L ${innerPts[i][0].toFixed(1)} ${innerPts[i][1].toFixed(1)}`;
  inner += " Z";

  let fibers = "";
  for (let i = 0; i < N; i += 3) {
    if (rnd() > 0.55) continue;
    const [x, y] = pts[i];
    const dx = x - cx;
    const dy = y - cy;
    const len = Math.hypot(dx, dy);
    const nx = dx / len;
    const ny = dy / len;
    const out = 4 + rnd() * 9;
    const tx = -ny * (rnd() - 0.5) * 6;
    const ty = nx * (rnd() - 0.5) * 6;
    fibers += `M ${x.toFixed(1)} ${y.toFixed(1)} L ${(x + nx * out + tx).toFixed(1)} ${(y + ny * out + ty).toFixed(1)} `;
  }
  return { outer, inner, fibers };
}

const torn = buildTornHole();

