---
const baseUrl = import.meta.env.BASE_URL;
const podcastUrl = `${baseUrl}podcast/`;

const pageTitle = "Мужские голоса — подкаст";
const pageDescription = "Подкаст про мужчин и для мужчин. О внутренней силе, уязвимости и пути, на котором мужчина учится быть собой.";
const ogImage = new URL(`${baseUrl}logo.jpg`, Astro.site).toString();
const pageUrl = new URL(baseUrl, Astro.site).toString();
const canonicalUrl = new URL(podcastUrl, Astro.site).toString();
---

<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:site_name" content="Мужские голоса" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="600" />
  <meta property="og:image:height" content="600" />
  <meta property="og:image:alt" content="Подкаст «Мужские голоса»" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" type="image/png" sizes="32x32" href={`${baseUrl}favicon/favicon-32x32.png`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${baseUrl}favicon/favicon-16x16.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${baseUrl}favicon/apple-touch-icon.png`} />
  <link rel="manifest" href={`${baseUrl}favicon/site.webmanifest`} />
  <link rel="shortcut icon" href={`${baseUrl}favicon/favicon.ico`} />
  <title>{pageTitle}</title>

  <meta http-equiv="refresh" content={`0;url=${podcastUrl}`} />
  <script is:inline define:vars={{ podcastUrl }}>
    window.location.replace(podcastUrl);
  </script>
</head>
<body>
  <p style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; padding: 24px;">
    Переходим к подкасту… Если страница не открылась сама —
    <a href={podcastUrl}>Мужские голоса</a>.
  </p>
</body>
</html>
