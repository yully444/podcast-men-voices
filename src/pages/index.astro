      <button data-apply-close style="width: 40px; height: 40px; font-size: var(--fs-h3); color: var(--ink-mute);" aria-label="Закрыть">×</button>
    </div>

    <div class="applyProgress" id="applyProgress">
      <span class="is-active"></span><span></span><span></span><span></span><span></span>
    </div>

    <div class="applyBody">
      <!-- Step 0: name -->
      <div class="applyStep is-active" data-step="0">
        <div class="mono" style="font-size: var(--fs-caption); letter-spacing: 0.22em; color: var(--accent); margin-bottom: 16px;">01 / ИМЯ</div>
        <h3 id="applyTitle" class="display" style="font-size: 36px; line-height: 1.1; margin-bottom: 12px;">Как к вам обращаться?</h3>
        <p style="font-size: var(--fs-body); color: var(--ink-mute); margin-bottom: 28px; line-height: 1.5;">Имя, как вам комфортно. Можно неформально.</p>
        <input class="applyField" type="text" id="applyName" placeholder="Например, Сергей" />
      </div>

      <!-- Step 1: contact -->
      <div class="applyStep" data-step="1">
        <div class="mono" style="font-size: var(--fs-caption); letter-spacing: 0.22em; color: var(--accent); margin-bottom: 16px;">02 / КОНТАКТ</div>
        <h3 class="display" style="font-size: 36px; line-height: 1.1; margin-bottom: 12px;">Как с вами связаться?</h3>
        <p style="font-size: var(--fs-body); color: var(--ink-mute); margin-bottom: 28px; line-height: 1.5;">Ведущий напишет лично — никаких рассылок, только собеседование.</p>
        <div style="display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap;" id="contactTypeChips">
          <button type="button" class="applyChip is-active" data-contact-type="telegram">Telegram</button>
          <button type="button" class="applyChip" data-contact-type="phone">Телефон</button>
          <button type="button" class="applyChip" data-contact-type="email">Email</button>
        </div>
        <input class="applyField" type="text" id="applyContact" placeholder="@username" />
      </div>

      <!-- Step 2: expectations -->
      <div class="applyStep" data-step="2">
        <div class="mono" style="font-size: var(--fs-caption); letter-spacing: 0.22em; color: var(--accent); margin-bottom: 16px;">03 / ЦЕЛИ</div>
        <h3 class="display" style="font-size: 36px; line-height: 1.1; margin-bottom: 12px;">Что вас сюда привело?</h3>
        <p style="font-size: var(--fs-body); color: var(--ink-mute); margin-bottom: 28px; line-height: 1.5;">Несколько фраз — что хотелось бы исследовать на мастерской. Это поможет настроить разговор.</p>
        <textarea class="applyField applyField--multi" id="applyExpectations" rows="4" placeholder="Свободно, без формальностей — для ведущего."></textarea>
        <div class="mono" id="applyExpectationsHint" style="margin-top: 8px; font-size: var(--fs-caption); letter-spacing: 0.22em; color: var(--ink-mute);">МИНИМУМ 6 СИМВОЛОВ</div>
      </div>

      <!-- Step 3: call time -->
      <div class="applyStep" data-step="3">
        <div class="mono" style="font-size: var(--fs-caption); letter-spacing: 0.22em; color: var(--accent); margin-bottom: 16px;">04 / ВРЕМЯ ЗВОНКА</div>
        <h3 class="display" style="font-size: 36px; line-height: 1.1; margin-bottom: 12px;">Когда удобнее созвониться?</h3>
        <p style="font-size: var(--fs-body); color: var(--ink-mute); margin-bottom: 28px; line-height: 1.5;">Ведущий свяжется с&nbsp;вами и&nbsp;предложит созвон-знакомство.</p>
        <div class="mono" style="font-size: var(--fs-caption); letter-spacing: 0.22em; color: var(--ink-mute); margin-bottom: 8px;">УДОБНОЕ ВРЕМЯ ДЛЯ созвона-знакомства</div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;" id="interviewChips">
          <button type="button" class="applyChip applyChip--accent is-active" data-interview="weekday-evening">Будни, вечер</button>
          <button type="button" class="applyChip applyChip--accent" data-interview="weekend">Выходные</button>
          <button type="button" class="applyChip applyChip--accent" data-interview="any">Любое</button>
        </div>
      </div>

      <!-- Step 4: confirmation -->
      <div class="applyStep" data-step="4">
        <div class="mono" style="font-size: var(--fs-caption); letter-spacing: 0.22em; color: var(--accent); margin-bottom: 16px;">05 / ПОДТВЕРЖДЕНИЕ</div>
        <h3 class="display" style="font-size: 36px; line-height: 1.1; margin-bottom: 12px;">Почти готово</h3>
        <p style="font-size: var(--fs-body); color: var(--ink-mute); margin-bottom: 28px; line-height: 1.5;">Прежде чем отправить — пара важных деталей.</p>
        <div style="background: var(--paper-2); padding: 24px; margin-bottom: 20px; font-size: var(--fs-body); line-height: 1.6; color: var(--ink-soft);">
          <p style="margin-bottom: 12px;">· Ведущий напишет в&nbsp;течение 1–2&nbsp;дней для короткого разговора.</p>
          <p style="margin-bottom: 12px;">· После собеседования мы&nbsp;подтвердим регистрацию и&nbsp;пришлём реквизиты для оплаты брони (90&nbsp;лари, 50%).</p>
          <p style="margin-bottom: 0;">· Заявка не&nbsp;обязывает — это начало разговора.</p>
        </div>
        <label id="applyAgreeWrap" style="display: flex; gap: 12px; padding: 16px; border: 1px solid var(--rule); cursor: pointer; align-items: flex-start; transition: border-color 200ms;">
          <input type="checkbox" id="applyAgree" style="margin-top: 4px; accent-color: var(--accent);" />
          <span style="font-size: var(--fs-body); color: var(--ink-soft); line-height: 1.5;">
            Согласен(на) с обработкой персональных данных и условиями участия.
          </span>
        </label>
      </div>

      <!-- Done state -->
      <div class="applyDone" id="applyDone">
        <div class="display" style="font-size: 64px; margin-bottom: 16px; color: var(--accent);">✓</div>
        <h3 class="display" style="font-size: 36px; margin-bottom: 16px; line-height: 1.1;">Заявка принята</h3>
        <p style="font-size: var(--fs-body); line-height: 1.6; color: var(--ink-soft); max-width: 460px; margin: 0 auto 28px;" id="applyDoneText">
          Спасибо. Ведущий свяжется с вами в течение 1–2 дней для короткого собеседования.
        </p>
        <button class="cta cta--outline" data-apply-close>
          <span>Закрыть</span>
          <span class="cta__arrow">→</span>
        </button>
      </div>

      <!-- Error state -->
      <div class="applyDone" id="applyError">
        <div class="display" style="font-size: 64px; margin-bottom: 16px; color: var(--ink-mute);">!</div>
        <h3 class="display" style="font-size: 36px; margin-bottom: 16px; line-height: 1.1;">Не удалось отправить</h3>
        <p style="font-size: var(--fs-body); line-height: 1.6; color: var(--ink-soft); max-width: 460px; margin: 0 auto 28px;">
          Что-то пошло не так с отправкой. Напишите Анри напрямую в Telegram — он свяжется с вами для собеседования.
        </p>
        <a class="cta cta--filled" href="https://t.me/sensologist" target="_blank" rel="noopener noreferrer" style="margin-bottom: 12px;">
          <span>Написать @sensologist</span>
          <span class="cta__arrow">→</span>
        </a>
        <div>
          <button class="cta cta--outline" data-apply-close>
            <span>Закрыть</span>
            <span class="cta__arrow">→</span>
          </button>
        </div>
      </div>

      <div class="applyNav" id="applyNav">
        <button type="button" id="applyBack" class="applyBack" disabled>← Назад</button>
        <button type="button" id="applyNext" class="cta cta--outline applyNext is-disabled">
          <span id="applyNextLabel">Дальше</span>
          <span class="cta__arrow">→</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // -- after-early-tier mode -------------------------------------------------
  // Switches pricing UI when the early-bird window closes:
  // 2026-05-20 00:00 GMT+4  ==  2026-05-19 20:00 UTC
  (function () {
    const EARLY_END_UTC = Date.UTC(2026, 4, 19, 20, 0, 0); // month is 0-indexed; 4 = May
    const params = new URLSearchParams(location.search);
    const force = params.get('after-early');
    let isAfter;
    if (force === '1') isAfter = true;
    else if (force === '0') isAfter = false;
    else isAfter = Date.now() >= EARLY_END_UTC;
    if (isAfter) document.body.classList.add('is-after-early');
  })();

  // -- nav scrolled state ----------------------------------------------------
  const nav = document.getElementById('siteNav');
  const onScroll = () => {
    if (window.scrollY > 60) nav.classList.add('is-scrolled');
    else nav.classList.remove('is-scrolled');
    const heroVoid = document.getElementById('heroVoid');
    const heroTitle = document.getElementById('heroTitle');
    if (heroVoid && heroTitle) {
      const voidShift = Math.min(window.scrollY * 0.15, 60);
      const titleShift = Math.min(window.scrollY * 0.06, 24);
      heroVoid.style.transform = `translateY(${voidShift * 0.3}px)`;
      heroTitle.style.transform = `translateY(${-titleShift}px)`;
    }
    const stb = document.getElementById('scrollTopBtn');
    if (stb) {
      if (window.scrollY > window.innerHeight) stb.classList.add('is-visible');
      else stb.classList.remove('is-visible');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  document.getElementById('scrollTopBtn').addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Scrollspy for desktop "О формате" section
  (function () {
    const sections = Array.from(document.querySelectorAll('[data-about-section]'));
    const navItems = Array.from(document.querySelectorAll('[data-about-nav]'));
    if (!sections.length || !navItems.length) return;
    const ACTIVE_OFFSET = 0.25; // section is "active" once its top crosses 25% of viewport
    let raf = null;
    const update = () => {
      raf = null;
      const threshold = window.innerHeight * ACTIVE_OFFSET;
      let activeIdx = -1;
      for (let i = 0; i < sections.length; i++) {
        const top = sections[i].getBoundingClientRect().top;
        if (top <= threshold) activeIdx = i;
      }
      navItems.forEach((item, i) => {
        item.classList.toggle('is-passed', activeIdx >= 0 && i < activeIdx);
        item.classList.toggle('is-active', i === activeIdx);
      });
    };
    const onScroll = () => { if (raf == null) raf = requestAnimationFrame(update); };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();

  // -- mobile menu ------------------------------------------------------------
  const menu = document.getElementById('menuOverlay');
  const burger = document.getElementById('burgerBtn');
  const menuClose = document.getElementById('menuClose');
  const openMenu = () => { menu.classList.add('is-open'); document.body.style.overflow = 'hidden'; };
  const closeMenu = () => { menu.classList.remove('is-open'); document.body.style.overflow = ''; };
  burger.addEventListener('click', openMenu);
  menuClose.addEventListener('click', closeMenu);
  document.querySelectorAll('[data-menu-link]').forEach((a) => {
    a.addEventListener('click', closeMenu);
  });

  // -- countdown --------------------------------------------------------------
  const target = new Date('2026-05-20T23:59:00+04:00').getTime();
  const cdEls = {
    d: document.querySelector('[data-cd="d"]'),
    h: document.querySelector('[data-cd="h"]'),
    m: document.querySelector('[data-cd="m"]'),
    s: document.querySelector('[data-cd="s"]'),
  };
  const banner = document.getElementById('countdownBanner');
  const tickCountdown = () => {
    const diff = Math.max(0, target - Date.now());
    if (diff <= 0) { banner.style.display = 'none'; return; }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff / 3600000) % 24);
    const m = Math.floor((diff / 60000) % 60);
    const s = Math.floor((diff / 1000) % 60);
    cdEls.d.textContent = String(d).padStart(2, '0');
    cdEls.h.textContent = String(h).padStart(2, '0');
    cdEls.m.textContent = String(m).padStart(2, '0');
    cdEls.s.textContent = String(s).padStart(2, '0');
  };
  tickCountdown();
  setInterval(tickCountdown, 1000);

  // -- apply modal ------------------------------------------------------------
  const overlay = document.getElementById('applyOverlay');
  const stepLabel = document.getElementById('applyStepLabel');
  const progress = document.getElementById('applyProgress');
  const backBtn = document.getElementById('applyBack');
  const nextBtn = document.getElementById('applyNext');
  const nextLabel = document.getElementById('applyNextLabel');
  const applyNav = document.getElementById('applyNav');
  const doneBlock = document.getElementById('applyDone');
  const doneText = document.getElementById('applyDoneText');
  const placeholders = { telegram: '@username', phone: '+995 ...', email: 'you@example.com' };
  let step = 0;
  const totalSteps = 5;
  const state = { name: '', contact: '', contactType: 'telegram', expectations: '', interview: 'weekday-evening', agreed: false };

  const setStep = (n) => {
    step = Math.max(0, Math.min(totalSteps - 1, n));
    document.querySelectorAll('.applyStep').forEach((el) => {
      el.classList.toggle('is-active', Number(el.dataset.step) === step);
    });
    stepLabel.textContent = `ЗАЯВКА · ШАГ ${step + 1} / ${totalSteps}`;
    Array.from(progress.children).forEach((bar, i) => {
      bar.classList.toggle('is-active', i <= step);
    });
    backBtn.disabled = step === 0;
    nextLabel.textContent = step === totalSteps - 1 ? 'Отправить заявку' : 'Дальше';
    updateNextEnabled();
    setTimeout(() => {
      const focus = document.querySelector('.applyStep.is-active input, .applyStep.is-active textarea');
      if (focus) focus.focus();
    }, 50);
  };

  const canNext = () => {
    if (step === 0) return state.name.trim().length > 1;
    if (step === 1) return state.contact.trim().length > 2;
    if (step === 2) return state.expectations.trim().length > 5;
    if (step === 3) return !!state.interview; // chip always has a default
    if (step === 4) return state.agreed;
    return false;
  };
  const updateNextEnabled = () => {
    if (canNext()) {
      nextBtn.classList.remove('is-disabled', 'cta--outline');
      nextBtn.classList.add('cta--filled');
    } else {
      nextBtn.classList.add('is-disabled');
      nextBtn.classList.remove('cta--filled');
      nextBtn.classList.add('cta--outline');
    }
  };

  document.querySelectorAll('[data-apply-open]').forEach((b) => {
    b.addEventListener('click', () => {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      doneBlock.classList.remove('is-active');
      applyNav.style.display = 'flex';
      progress.style.display = 'flex';
      setStep(0);
    });
  });
  document.querySelectorAll('[data-apply-close]').forEach((b) => {
    b.addEventListener('click', () => {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  });

  document.getElementById('applyName').addEventListener('input', (e) => { state.name = e.target.value; updateNextEnabled(); });
  document.getElementById('applyContact').addEventListener('input', (e) => { state.contact = e.target.value; updateNextEnabled(); });
  const expectationsHint = document.getElementById('applyExpectationsHint');
  document.getElementById('applyExpectations').addEventListener('input', (e) => {
    state.expectations = e.target.value;
    const len = state.expectations.trim().length;
    if (len > 5) {
      expectationsHint.textContent = `${len} СИМВОЛОВ`;
      expectationsHint.style.color = 'var(--accent)';
    } else {
      expectationsHint.textContent = len > 0 ? `${len} / 6 СИМВОЛОВ` : 'МИНИМУМ 6 СИМВОЛОВ';
      expectationsHint.style.color = 'var(--ink-mute)';
    }
    updateNextEnabled();
  });
  document.getElementById('applyAgree').addEventListener('change', (e) => {
    state.agreed = e.target.checked;
    document.getElementById('applyAgreeWrap').style.borderColor = state.agreed ? 'var(--ink)' : 'var(--rule)';
    updateNextEnabled();
  });

  document.querySelectorAll('#contactTypeChips [data-contact-type]').forEach((b) => {
    b.addEventListener('click', () => {
      state.contactType = b.dataset.contactType;
      document.querySelectorAll('#contactTypeChips [data-contact-type]').forEach((x) => x.classList.toggle('is-active', x === b));
      const inp = document.getElementById('applyContact');
      inp.placeholder = placeholders[state.contactType];
      inp.focus();
    });
  });
  document.querySelectorAll('#interviewChips [data-interview]').forEach((b) => {
    b.addEventListener('click', () => {
      state.interview = b.dataset.interview;
      document.querySelectorAll('#interviewChips [data-interview]').forEach((x) => x.classList.toggle('is-active', x === b));
    });
  });

  backBtn.addEventListener('click', () => { if (step > 0) setStep(step - 1); });

  const FORM_URL = 'https://docs.google.com/forms/d/e/1FAIpQLScezKnWmzmj9BC58Mns5o0Irs1b4H145dc4jlPgtIwtfqFD1Q/formResponse';
  const CONTACT_TYPE_MAP = { telegram: 'Telegram', phone: 'Телефон', email: 'Email' };
  const INTERVIEW_MAP = { 'weekday-evening': 'Будни, вечер', weekend: 'Выходные', any: 'Любое' };
  const errorBlock = document.getElementById('applyError');

  const showResult = (block) => {
    document.querySelectorAll('.applyStep').forEach((el) => el.classList.remove('is-active'));
    doneBlock.classList.remove('is-active');
    errorBlock.classList.remove('is-active');
    block.classList.add('is-active');
    applyNav.style.display = 'none';
    progress.style.display = 'none';
  };

  nextBtn.addEventListener('click', () => {
    if (!canNext()) return;
    if (step < totalSteps - 1) {
      setStep(step + 1);
      return;
    }
    // submit to Google Forms
    nextBtn.classList.add('is-disabled');
    backBtn.disabled = true;
    nextLabel.textContent = 'Отправляется…';

    const body = new URLSearchParams();
    body.set('entry.1925631356', state.name);
    body.set('entry.1979587863', CONTACT_TYPE_MAP[state.contactType] || '');
    body.set('entry.204819364', state.contact);
    body.set('entry.454240511', state.expectations);
    body.set('entry.1045321552', INTERVIEW_MAP[state.interview] || '');

    fetch(FORM_URL, { method: 'POST', mode: 'no-cors', body })
      .then(() => {
        stepLabel.textContent = 'ЗАЯВКА · ПРИНЯТА';
        const firstName = (state.name.split(' ')[0] || 'брат').trim();
        doneText.textContent = `Спасибо, ${firstName}. Ведущий свяжется с вами в течение 1–2 дней для короткого собеседования. После него мы подтвердим регистрацию и вышлем реквизиты для оплаты брони.`;
        showResult(doneBlock);
      })
      .catch(() => {
        stepLabel.textContent = 'ЗАЯВКА · ОШИБКА';
        showResult(errorBlock);
      });
  });
</script>
</body>
</html>
