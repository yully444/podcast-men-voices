---
interface Props {
  title?: string;
  description?: string;
  episodeTitle?: string;
}

const {
  title = "Мужские голоса — подкаст",
  description = "Подкаст про мужчин и для мужчин. О внутренней силе, уязвимости и пути, на котором мужчина учится быть собой.",
  episodeTitle,
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href={`${import.meta.env.BASE_URL}podcast/`} class="site-brand">
          <img
            src={`${import.meta.env.BASE_URL}logo.jpg`}
            alt=""
            class="site-logo"
            width="32"
            height="32"
          />
          <span class="site-title">Мужские голоса</span>
        </a>
        {!episodeTitle && <span class="site-tagline">подкаст</span>}
        {episodeTitle && (
          <span class="site-meta">
            <span class="site-sep" aria-hidden="true">·</span>
            <span class="site-episode">{episodeTitle}</span>
          </span>
        )}
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Ведущие: <a href="https://t.me/sensologist" target="_blank" rel="noopener noreferrer">Анри</a> и
        <a href="https://t.me/AlexanderOlnev" target="_blank" rel="noopener noreferrer">Александр</a>
      </p>
    </footer>

    <style is:global>
      :root {
        --color-text: #1a1a1a;
        --color-muted: #6b6b6b;
        --color-bg: #ffffff;
        --color-border: #e5e5e5;
        --color-accent: #f5d116;
        --color-brand: #2b6e9b;
        --font-serif: Georgia, "Times New Roman", serif;
        --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica,
          Arial, sans-serif;
        --content-width: 720px;
        --header-height: 60px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        font-family: var(--font-serif);
        font-size: 18px;
        line-height: 1.6;
        color: var(--color-text);
        background: var(--color-bg);
      }

      a {
        color: var(--color-text);
        text-decoration: underline;
        text-decoration-color: var(--color-border);
        text-underline-offset: 3px;
      }

      a:hover {
        text-decoration-color: var(--color-text);
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-sans);
        line-height: 1.25;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        background: var(--color-bg);
        padding: 16px 24px;
        display: flex;
        align-items: baseline;
        gap: 12px;
        border-bottom: 1px solid var(--color-border);
        min-height: var(--header-height);
      }

      .site-header-inner {
        max-width: var(--content-width);
        margin: 0 auto;
        width: 100%;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
      }

      .site-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        flex-shrink: 0;
      }

      .site-logo {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: block;
      }

      .site-meta {
        font-family: var(--font-sans);
        font-size: 18px;
        line-height: 1;
        color: var(--color-muted);
        display: flex;
        align-items: baseline;
        gap: 8px;
        min-width: 0;
        overflow: hidden;
      }

      .site-sep {
        color: var(--color-border);
        flex-shrink: 0;
      }

      .site-episode {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
      }

      .site-title {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 18px;
        line-height: 1;
        text-decoration: none;
      }

      .site-tagline {
        font-family: var(--font-sans);
        color: var(--color-muted);
        font-size: 18px;
        line-height: 1;
      }

      .site-main {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 32px 24px 64px;
      }

      .site-footer {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 24px 24px 48px;
        border-top: 1px solid var(--color-border);
        font-family: var(--font-sans);
        font-size: 14px;
        color: var(--color-muted);
        line-height: 1.4;
      }

      .site-footer p {
        margin: 0;
      }
    </style>
  </body>
</html>
