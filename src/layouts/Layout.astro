---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Мужские голоса — подкаст",
  description = "Подкаст про мужчин и для мужчин. О внутренней силе, уязвимости и пути, на котором мужчина учится быть собой.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">Мужские голоса</a>
      <span class="site-tagline">подкаст</span>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Ведущие: <a href="https://t.me/sensologist" rel="noopener">Анри</a> и
        <a href="https://t.me/AlexanderOlnev" rel="noopener">Александр</a>
      </p>
    </footer>

    <style is:global>
      :root {
        --color-text: #1a1a1a;
        --color-muted: #6b6b6b;
        --color-bg: #ffffff;
        --color-border: #e5e5e5;
        --color-accent: #f5d116;
        --font-serif: Georgia, "Times New Roman", serif;
        --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica,
          Arial, sans-serif;
        --content-width: 720px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        font-family: var(--font-serif);
        font-size: 18px;
        line-height: 1.6;
        color: var(--color-text);
        background: var(--color-bg);
      }

      a {
        color: var(--color-text);
        text-decoration: underline;
        text-decoration-color: var(--color-border);
        text-underline-offset: 3px;
      }

      a:hover {
        text-decoration-color: var(--color-text);
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-sans);
        line-height: 1.25;
      }

      .site-header {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 32px 24px 16px;
        display: flex;
        align-items: baseline;
        gap: 12px;
        border-bottom: 1px solid var(--color-border);
      }

      .site-title {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 20px;
        text-decoration: none;
      }

      .site-tagline {
        font-family: var(--font-sans);
        color: var(--color-muted);
        font-size: 14px;
      }

      .site-main {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 32px 24px 64px;
      }

      .site-footer {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 24px 24px 48px;
        border-top: 1px solid var(--color-border);
        font-family: var(--font-sans);
        font-size: 14px;
        color: var(--color-muted);
      }

      .site-footer p {
        margin: 0;
      }
    </style>
  </body>
</html>
