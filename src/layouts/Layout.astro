---
interface Props {
  title?: string;
  description?: string;
  episodeTitle?: string;
}

const {
  title = "Мужские голоса — подкаст",
  description = "Подкаст про мужчин и для мужчин. О внутренней силе, уязвимости и пути, на котором мужчина учится быть собой.",
  episodeTitle,
} = Astro.props;

const ogImage = new URL(`${import.meta.env.BASE_URL}logo.jpg`, Astro.site).toString();
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="Мужские голоса" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="600" />
    <meta property="og:image:height" content="600" />
    <meta property="og:image:alt" content="Подкаст «Мужские голоса»" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon/favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon/favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}favicon/apple-touch-icon.png`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}favicon/site.webmanifest`} />
    <link rel="shortcut icon" href={`${import.meta.env.BASE_URL}favicon/favicon.ico`} />
    <title>{title}</title>

    <!-- Yandex.Metrika counter -->
    <script type="text/javascript" is:inline>
      (function(m,e,t,r,i,k,a){
          m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
          m[i].l=1*new Date();
          for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
          k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
      })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=109241048', 'ym');

      ym(109241048, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/109241048" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrika counter -->

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KBY7G1DT53" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-KBY7G1DT53');
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a href={`${import.meta.env.BASE_URL}podcast/`} class="site-brand">
          <img
            src={`${import.meta.env.BASE_URL}logo.jpg`}
            alt=""
            class="site-logo"
            width="32"
            height="32"
          />
          <span class="site-title">Мужские голоса</span>
        </a>
        {!episodeTitle && <span class="site-tagline">подкаст</span>}
        {episodeTitle && (
          <span class="site-meta">
            <span class="site-sep" aria-hidden="true">·</span>
            <span class="site-episode">{episodeTitle}</span>
          </span>
        )}
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Ведущие: <a href="https://t.me/sensologist" target="_blank" rel="noopener noreferrer">Анри</a> и
        <a href="https://t.me/AlexanderOlnev" target="_blank" rel="noopener noreferrer">Александр</a>
      </p>
    </footer>

    <style is:global>
      :root {
        --color-text: #1a1a1a;
        --color-muted: #6b6b6b;
        --color-bg: #ffffff;
        --color-border: #e5e5e5;
        --color-accent: #f5d116;
        --color-brand: #2b6e9b;
        --font-serif: Georgia, "Times New Roman", serif;
        --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica,
          Arial, sans-serif;
        --content-width: 720px;
        --header-height: 60px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        font-family: var(--font-serif);
        font-size: 18px;
        line-height: 1.6;
        color: var(--color-text);
        background: var(--color-bg);
      }

      a {
        color: var(--color-text);
        text-decoration: underline;
        text-decoration-color: var(--color-border);
        text-underline-offset: 3px;
      }

      a:hover {
        text-decoration-color: var(--color-text);
      }

      h1,
      h2,
      h3 {
        font-family: var(--font-sans);
        line-height: 1.25;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        background: var(--color-bg);
        padding: 16px 24px;
        display: flex;
        align-items: baseline;
        gap: 12px;
        border-bottom: 1px solid var(--color-border);
        min-height: var(--header-height);
      }

      .site-header-inner {
        max-width: var(--content-width);
        margin: 0 auto;
        width: 100%;
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
      }

      .site-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        flex-shrink: 0;
      }

      .site-logo {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        display: block;
      }

      .site-meta {
        font-family: var(--font-sans);
        font-size: 18px;
        line-height: 1;
        color: var(--color-muted);
        display: flex;
        align-items: baseline;
        gap: 8px;
        min-width: 0;
        overflow: hidden;
      }

      .site-sep {
        color: var(--color-border);
        flex-shrink: 0;
      }

      .site-episode {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
      }

      .site-title {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: 18px;
        line-height: 1;
        text-decoration: none;
      }

      .site-tagline {
        font-family: var(--font-sans);
        color: var(--color-muted);
        font-size: 18px;
        line-height: 1;
      }

      .site-main {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 32px 24px 64px;
      }

      .site-footer {
        max-width: var(--content-width);
        margin: 0 auto;
        padding: 24px 24px 48px;
        border-top: 1px solid var(--color-border);
        font-family: var(--font-sans);
        font-size: 14px;
        color: var(--color-muted);
        line-height: 1.4;
      }

      .site-footer p {
        margin: 0;
      }
    </style>
  </body>
</html>
