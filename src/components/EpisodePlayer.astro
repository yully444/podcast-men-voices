---
interface Props {
  audioUrl?: string;
  embedUrl?: string;
  title: string;
}

const { audioUrl, embedUrl, title } = Astro.props;
---

{
  audioUrl && (
    <div class="player">
      <audio controls preload="metadata" src={audioUrl} aria-label={title}>
        Ваш браузер не поддерживает HTML5 аудио.
      </audio>
    </div>
  )
}

{
  !audioUrl && embedUrl && (
    <div class="player player--embed">
      <iframe
        src={embedUrl}
        title={title}
        loading="lazy"
        allow="autoplay; encrypted-media"
      />
    </div>
  )
}

{
  !audioUrl && !embedUrl && (
    <div class="player player--placeholder">
      <p>Аудио будет добавлено позже.</p>
    </div>
  )
}

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest<HTMLElement>("[data-seek]");
    if (!button) return;
    const seek = Number(button.dataset.seek);
    if (!Number.isFinite(seek)) return;
    const audio = document.querySelector<HTMLAudioElement>("audio");
    if (!audio) return;
    audio.currentTime = seek;
    audio.play().catch(() => {});
  });
</script>

<style>
  .player {
    position: sticky;
    top: var(--header-height);
    z-index: 20;
    margin: 24px 0 32px;
    padding: 12px 0;
    background: var(--color-bg);
  }

  .player audio {
    width: 100%;
  }

  .player--embed iframe {
    width: 100%;
    min-height: 180px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .player--placeholder {
    padding: 16px 20px;
    background: #fafafa;
    border: 1px dashed var(--color-border);
    border-radius: 12px;
    color: var(--color-muted);
    font-family: var(--font-sans);
    font-size: 14px;
  }

  .player--placeholder p {
    margin: 0;
  }
</style>
